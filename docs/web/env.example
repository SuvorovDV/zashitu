# База данных (asyncpg для FastAPI, psycopg2 для Celery)
DATABASE_URL=postgresql+asyncpg://zashitu:zashitu_pass@localhost:5432/zashitu_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT — сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_replace_me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe — получить на https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Получить при запуске: stripe listen --forward-to localhost:8000/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic (для реального генератора)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — адрес фронтенда
FRONTEND_URL=http://localhost:5173

# Директории для файлов (создаются автоматически при старте)
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Режим генерации: mock (без Claude API) или real (реальный генератор из бота)
GENERATION_MODE=mock

# Путь к коду бота (только для GENERATION_MODE=real)
ZASHITU_PATH=../zashitu

# Cookies: True в production (HTTPS); False только для локальной разработки
COOKIE_SECURE=True
COOKIE_SAMESITE=lax

# Dev-режим (только для локальной разработки). В production оставить пустыми.
DEV_MODE=False
DEV_TOKEN=
CELERY_TASK_ALWAYS_EAGER=False
