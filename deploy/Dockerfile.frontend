# Фронт: Vite build → Caddy static + auto-TLS reverse-proxy.
FROM node:20-alpine AS build

WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
# Vite запекает VITE_-переменные во время build'а.
ARG VITE_DEV_TOKEN=""
ENV VITE_DEV_TOKEN=$VITE_DEV_TOKEN
RUN npm run build

FROM caddy:2.8-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv

EXPOSE 80 443
