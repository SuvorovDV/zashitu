# Рабочий публичный домен + старый nip.io оставляем на время перехода,
# Caddy получит TLS-серты для каждого по HTTP-01 challenge от Let's Encrypt.
# www-префикс тоже обрабатываем — редирект на apex внутри блока.
get-tezis.ru, www.get-tezis.ru, tezis.176.12.79.36.nip.io {
    encode gzip zstd

    # www → apex редирект (301), чтобы была одна каноническая ссылка.
    @www host www.get-tezis.ru
    redir @www https://get-tezis.ru{uri} 301

    # API → backend. handle'ы взаимоисключающие; совпадение по пути → только в этот handle.
    @api path /auth* /orders* /payments* /generation* /files* /health* /dev*
    handle @api {
        reverse_proxy backend:8000
    }

    # Иммутабельный кэш для Vite-бандлов (хешированные имена /assets/index-XXX.js).
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # index.html НЕ кэшируется — иначе после деплоя браузер тянет старый html
    # с устаревшими ссылками на хешированные бандлы и продолжает ловить старый JS.
    @html path / /index.html
    header @html Cache-Control "no-cache, must-revalidate"

    # SPA-фоллбэк: всё прочее — статика + try_files.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    request_body {
        max_size 25MB
    }
}
