# ── Bot ────────────────────────────────────────────────────────────────
BOT_TOKEN=
BACKEND_URL=http://localhost:8000
BACKEND_INTERNAL_SECRET=
# (опц.) Прокси к api.telegram.org, если хост блокирует TG. Пусто = напрямую.
# На серверах за пределами РФ (Казахстан, Европа и т.д.) не нужен.
# TELEGRAM_API_SERVER=https://your-proxy.workers.dev
DEBUG_SKIP_PAYMENT=false

# ── Backend (zashitu-web/backend) ──────────────────────────────────────
# PostgreSQL + Redis поднимаются как соседние сервисы в docker-compose.
DATABASE_URL=postgresql+asyncpg://zashitu:zashitu_pass@localhost:5432/zashitu_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT — сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Тот же секрет, что BACKEND_INTERNAL_SECRET — бэкенд проверяет X-Bot-Secret
BOT_INTERNAL_SECRET=
BOT_SERVICE_USER_EMAIL=bot@zashitu.internal

# Оплата
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Режим генерации: mock (без Claude API) или real
GENERATION_MODE=mock

# CORS
FRONTEND_URL=http://localhost:5173

# Файлы
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE_MB=20

# Куки: True в prod (HTTPS), False только в локальной разработке
COOKIE_SECURE=True
COOKIE_SAMESITE=lax

# Dev
DEV_MODE=False
DEV_TOKEN=
CELERY_TASK_ALWAYS_EAGER=False
